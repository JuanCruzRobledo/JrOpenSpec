# =============================================================================
# Integrador — Variables de Entorno
# Copiar a .env y ajustar valores segun el entorno
# =============================================================================

# --- Base de Datos (PostgreSQL) ---
POSTGRES_USER=buensabor
POSTGRES_PASSWORD=buensabor_dev_2024
POSTGRES_DB=buensabor
DATABASE_URL=postgresql+asyncpg://buensabor:buensabor_dev_2024@postgres:5432/buensabor

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Entorno ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
API_PREFIX=/api

# --- Seguridad (JWT) --- configurar en Phase 2
# JWT_SECRET=cambiar-en-produccion
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Table Token (HMAC) --- configurar en Phase 2
# TABLE_TOKEN_SECRET=cambiar-en-produccion
# TABLE_TOKEN_EXPIRE_HOURS=3

# --- CORS ---
CORS_ORIGINS=http://localhost:5176,http://localhost:5177,http://localhost:5178
