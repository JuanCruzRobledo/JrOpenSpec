# =============================================================================
# Integrador — Variables de Entorno
# =============================================================================
# Copiar este archivo como .env y completar con valores locales:
#   cp env.example .env
# =============================================================================

# --- Base de Datos (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://integrador:integrador@localhost:5432/integrador
POSTGRES_DB=integrador
POSTGRES_USER=integrador
POSTGRES_PASSWORD=integrador

# --- Redis ---
REDIS_URL=redis://localhost:6380/0

# --- Entorno ---
ENVIRONMENT=dev
DEBUG=true
LOG_LEVEL=INFO

# --- Seguridad (JWT) ---
# Generar con: openssl rand -hex 32
JWT_SECRET=cambiar-este-secreto-en-produccion
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Table Token (HMAC para comensales) ---
# Generar con: openssl rand -hex 32
TABLE_TOKEN_SECRET=cambiar-este-secreto-en-produccion
TABLE_TOKEN_EXPIRE_HOURS=3

# --- CORS ---
CORS_ORIGINS=http://localhost:5176,http://localhost:5177,http://localhost:5178

# --- API ---
API_PREFIX=/api

# --- Frontends (Vite) ---
# Cada frontend define estas variables en su propio .env:
#   VITE_API_URL=http://localhost:8000/api
#   VITE_WS_URL=ws://localhost:8001
#   VITE_BRANCH_SLUG=default (solo pwaMenu)
